local function loadSlotNames()
    pcall(function()
        if isfile and isfile("flashback_names.txt") then
            local raw = readfile("flashback_names.txt")
            local lines = splitStr(raw, "\n")
            for i = 1, 5 do
                slotNames[i] = lines[i] or ""
            end
