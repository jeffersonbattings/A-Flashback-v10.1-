UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode==Enum.KeyCode.R then
        if not recording then startRecording() else stopRecording() end
    elseif input.KeyCode==Enum.KeyCode.P then playReplay()
    elseif input.KeyCode==Enum.KeyCode.F then enableFreecam(not FreecamEnabled)
    elseif input.KeyCode==Enum.KeyCode.X then cleanupGhosts()
    elseif input.KeyCode==Enum.KeyCode.Left then
        playbackSpeed=0; playbackIndex=math.clamp(playbackIndex-1,1,#replayData)
    elseif input.KeyCode==Enum.KeyCode.Right then
        playbackSpeed=0; playbackIndex=math.clamp(playbackIndex+1,1,#replayData)
    elseif input.KeyCode==Enum.KeyCode.J then
        if not camPathRecording then startCamPathRec() else stopCamPathRec() end
    elseif input.KeyCode==Enum.KeyCode.K then
        playCamPath()
    elseif input.KeyCode==Enum.KeyCode.L then
