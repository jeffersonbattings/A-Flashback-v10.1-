local function makeLbl(parent, order, text)
    local l = Instance.new("TextLabel", parent)
    l.LayoutOrder = order
    l.Size = UDim2.new(1, 0, 0, 11)
    l.BackgroundTransparency = 1
    l.TextColor3 = Color3.fromRGB(100, 100, 100)
    l.TextSize = 8
    l.Font = Enum.Font.GothamBold
    l.Text = text
    l.TextXAlignment = Enum.TextXAlignment.Left
    return l
end

local function makeSep(parent, order)
    local s = Instance.new("Frame", parent)
    s.LayoutOrder = order
    s.Size = UDim2.new(1, 0, 0, 1)
    s.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    s.BorderSizePixel = 0
end

local function makeRow(parent, order, labelA, labelB, cbA, cbB)
    local row = Instance.new("Frame", parent)
    row.LayoutOrder = order
    row.Size = UDim2.new(1, 0, 0, 20)
    row.BackgroundTransparency = 1
    local rl = Instance.new("UIListLayout", row)
    rl.FillDirection = Enum.FillDirection.Horizontal
    rl.Padding = UDim.new(0, 3)
    rl.HorizontalAlignment = Enum.HorizontalAlignment.Center
    local function rb(text, cb)
        local b = Instance.new("TextButton", row)
        b.Size = UDim2.new(0.48, 0, 1, 0)
        b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
        b.Font = Enum.Font.GothamMedium
        b.TextSize = 9
        b.Text = text
        b.AutoButtonColor = true
        Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
        b.MouseButton1Click:Connect(cb)
        return b
    end
    rb(labelA, cbA)
    rb(labelB, cbB)
end

local function makeTextBox(parent, order, placeholder)
    local box = Instance.new("TextBox", parent)
    box.LayoutOrder = order
    box.Size = UDim2.new(1, 0, 0, 18)
    box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    box.TextColor3 = Color3.fromRGB(200, 200, 200)
    box.PlaceholderText = placeholder
    box.PlaceholderColor3 = Color3.fromRGB(65, 65, 65)
    box.TextSize = 8
    box.Font = Enum.Font.GothamMedium
    box.Text = ""
    box.ClearTextOnFocus = false
    box.BorderSizePixel = 0
    box.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)
    local p = Instance.new("UIPadding", box)
    p.PaddingLeft = UDim.new(0, 4)
    return box
end

