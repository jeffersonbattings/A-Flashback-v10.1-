local ji,jn,jc={},{},0
local function gjid(name)
	if not ji[name] then jc+=1;ji[name]=jc;jn[jc]=name end
	return ji[name]
end
local function cfn(cf)
	local x,y,z=cf.XVector,cf.YVector,cf.ZVector
	return cf.X,cf.Y,cf.Z,x.X,y.X,z.X,x.Y,y.Y,z.Y,x.Z,y.Z,z.Z
end
local function ncf(a,b,c,d,e,f,g,h,i,j,k,l)return CFrame.new(a,b,c,d,e,f,g,h,i,j,k,l)end
local function fmt(n)return tostring(math.floor(n*1000000+0.5))end

local function serialize(data)
	ji={};jn={};jc=0
	for _,fr in ipairs(data)do for _,pd in pairs(fr)do for jname in pairs(pd.Joints)do gjid(jname)end end end
	local out={table.concat(jn,",").."\n"}
	for _,fr in ipairs(data)do
		local fp={}
		for id,pd in pairs(fr)do
			local a,b,c,d,e,f,g,h,i,j,k,l=cfn(pd.Pivot)
			local pts={id,fmt(a),fmt(b),fmt(c),fmt(d),fmt(e),fmt(f),fmt(g),fmt(h),fmt(i),fmt(j),fmt(k),fmt(l)}
			for jname,jt in pairs(pd.Joints)do
				local ja,jb,jc2,jd,je,jf,jg,jh,ji2,jj,jk,jl=cfn(jt)
				table.insert(pts,ji[jname]..","..fmt(ja)..","..fmt(jb)..","..fmt(jc2)..","..fmt(jd)..","..fmt(je)..","..fmt(jf)..","..fmt(jg)..","..fmt(jh)..","..fmt(ji2)..","..fmt(jj)..","..fmt(jk)..","..fmt(jl))
			end
			fp[#fp+1]=table.concat(pts,";")
		end
		out[#out+1]=table.concat(fp,"|").."\n"
	end
	return table.concat(out)
end
FB.serializeReplay=serialize

local function deserialize(raw)
	local lines=split(raw,"\n")
	if #lines<2 then error("too few lines")end
	local ljn=split(lines[1],",");local data={}
	local function p(n)local v=tonumber(n);if not v then error("bad number")end;return v/1000000 end
	for li=2,#lines do
		local frame={}
		for _,pc in ipairs(split(lines[li],"|"))do
			local segs=split(pc,";")
			if #segs>=13 then
				local id=segs[1]
				local pivot=ncf(p(segs[2]),p(segs[3]),p(segs[4]),p(segs[5]),p(segs[6]),p(segs[7]),p(segs[8]),p(segs[9]),p(segs[10]),p(segs[11]),p(segs[12]),p(segs[13]))
				local joints={}
				for si=14,#segs do
					local jp=split(segs[si],",")
					if #jp==13 then
						local jid=tonumber(jp[1]);local jname=jid and ljn[jid]
						if jname then joints[jname]=ncf(p(jp[2]),p(jp[3]),p(jp[4]),p(jp[5]),p(jp[6]),p(jp[7]),p(jp[8]),p(jp[9]),p(jp[10]),p(jp[11]),p(jp[12]),p(jp[13]))end
					end
				end
				frame[id]={Pivot=pivot,Joints=joints}
			end
		end
		if next(frame)then data[#data+1]=frame end
	end
	return data
end
FB.deserializeReplay=deserialize

