local function showPage(n)
    currentPage=n
    page1.Visible=n==1; page2.Visible=n==2; page3.Visible=n==3
    page4.Visible=n==4; page5.Visible=n==5; page6.Visible=n==6
    backBtn.Visible=n>1; nextBtn.Visible=n<6
    local labels={"Page 2 →","Page 3 →","Page 4 →","Page 5 →","Page 6 →"}
    if n<6 then nextBtn.Text=labels[n] end
end

