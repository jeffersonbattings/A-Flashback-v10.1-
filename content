local function spawnGhosts(ff)
	for id in pairs(ff)do
		local uid=tonumber(id)
		local tp=Players:GetPlayerByUserId(uid)
		local sc=(tp and tp.Character)or(uid==lp.UserId and lp.Character)
		if sc then
			local hum=sc:FindFirstChildOfClass("Humanoid")
			local ar=hum and hum:FindFirstChildOfClass("Animator");if ar then ar:Destroy()end
			local an=sc:FindFirstChild("Animate");if an then an.Disabled=true end
			sc.Archivable=true;local clone=sc:Clone();sc.Archivable=false
			if an then an.Disabled=false end
			if hum then Instance.new("Animator").Parent=hum end
			if clone then
				clone.Name="Flashback_Ghost"
				for _,v in ipairs(clone:GetDescendants())do if v:IsA("Script")or v:IsA("LocalScript")then v:Destroy()end end
				for _,v in ipairs(clone:GetDescendants())do if v:IsA("Animation")then v:Destroy()end end
				local ch=clone:FindFirstChildOfClass("Humanoid")
				if ch then local a=ch:FindFirstChildOfClass("Animator");if a then a:Destroy()end;ch.DisplayDistanceType=Enum.HumanoidDisplayDistanceType.None end
				local ca=clone:FindFirstChild("Animate");if ca then ca:Destroy()end
				for _,pt in ipairs(clone:GetDescendants())do if pt:IsA("BasePart")then pt.CanCollide=false;pt.Anchored=(pt.Name=="HumanoidRootPart")end end
				local cj={}
				for _,v in ipairs(clone:GetDescendants())do if v:IsA("Motor6D")then cj[v.Name]=v end end
				clone.Parent=workspace;activeClones[id]={Model=clone,Joints=cj}
			end
		end
	end
end

local function playReplay()
	if #replayData==0 then warn("No replay data.")return end
	cleanupGhosts();task.wait(0.1)
	playbackIndex=1;isPlaying=true;activeClones={}
	local ff=replayData[1];if not ff then isPlaying=false;return end
	spawnGhosts(ff)
	task.spawn(function()
		while isPlaying do
			playbackIndex=math.clamp(playbackIndex+playbackSpeed,1,#replayData)
			local fd=replayData[math.floor(playbackIndex)]
			if fd then
				for id,g in pairs(activeClones)do
					local pf=fd[id]
					if pf and g.Model then
						g.Model:PivotTo(pf.Pivot)
						for jn2,t in pairs(pf.Joints)do local j=g.Joints[jn2];if j then j.C0=t*j.C1 end end
					end
				end
			end
			motionBlur.Size=motionBlurEnabled and math.abs(playbackSpeed-1)*8 or 0
			updateFL()
			local atEnd=playbackIndex>=#replayData and playbackSpeed>0
			local atStart=playbackIndex<=1 and playbackSpeed<0
			if atEnd or atStart then
				if loopPlayback then playbackIndex=playbackSpeed>0 and 1 or #replayData else break end
			end
			task.wait(1/60)
		end
		if not loopPlayback then cleanupGhosts()end
	end)
end
FB.playReplay=playReplay

