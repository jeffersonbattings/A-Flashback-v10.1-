local function updateFrameLabel()
    if frameCountLabel then
        local total = #replayData
        local secs = math.floor(total/60)
        local frames = total%60
        if isPlaying then
            frameCountLabel.Text = ("▶ %d / %d  |  %ds %df"):format(math.floor(playbackIndex),total,secs,frames)
        elseif recording then
            frameCountLabel.Text = ("⏺ %d frames  |  %ds %df"):format(total,math.floor(total/60),total%60)
        else
            frameCountLabel.Text = ("Frames: %d  |  %ds %df"):format(total,secs,frames)
        end
    end
end

