local function startRecording()
    replayData = {}
    recording = true
    updateRecordBtn()
    task.spawn(function()
        local frameCount = 0
        while recording do
            frameCount += 1
            local frame = {}
            local targets = recordAll and Players:GetPlayers() or {lp}
            for _, p in ipairs(targets) do
                if p.Character then
                    local joints = {}
                    for _, v in ipairs(p.Character:GetDescendants()) do
                        if v:IsA("Motor6D") and v.Part0 and v.Part1 then
                            joints[v.Name] = v.C0 * v.Transform * v.C1:Inverse()
                        end
                    end
                    frame[tostring(p.UserId)] = {Pivot = p.Character:GetPivot(), Joints = joints}
                end
            end
            replayData[frameCount] = frame
            updateFrameLabel()
            task.wait(1/60)
        end
    end)
end

local function stopRecording()
    recording = false
    updateRecordBtn()
    updateFrameLabel()
end

local function spawnGhosts(firstFrame)
    for id, _ in pairs(firstFrame) do
        local userId = tonumber(id)
        local targetPlayer = Players:GetPlayerByUserId(userId)
        local sourceChar = (targetPlayer and targetPlayer.Character) or (userId == lp.UserId and lp.Character)
        if sourceChar then
            local hum = sourceChar:FindFirstChildOfClass("Humanoid")
            local animatorRef = hum and hum:FindFirstChildOfClass("Animator")
            if animatorRef then animatorRef:Destroy() end
            local animateRef = sourceChar:FindFirstChild("Animate")
            if animateRef then animateRef.Disabled = true end
            sourceChar.Archivable = true
            local clone = sourceChar:Clone()
            sourceChar.Archivable = false
            if animateRef then animateRef.Disabled = false end
            if hum then Instance.new("Animator").Parent = hum end
            if clone then
                clone.Name = "Flashback_Ghost"
                for _, v in ipairs(clone:GetDescendants()) do
                    if v:IsA("Script") or v:IsA("LocalScript") then v:Destroy() end
                end
                local cloneHum = clone:FindFirstChildOfClass("Humanoid")
                if cloneHum then
                    local a = cloneHum:FindFirstChildOfClass("Animator")
                    if a then a:Destroy() end
                end
                local ca = clone:FindFirstChild("Animate")
                if ca then ca:Destroy() end
                for _, part in ipairs(clone:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = false
                        part.Anchored = (part.Name == "HumanoidRootPart")
                    end
                end
                local cloneJoints = {}
                for _, v in ipairs(clone:GetDescendants()) do
                    if v:IsA("Motor6D") then cloneJoints[v.Name] = v end
                end
                clone.Parent = workspace
                activeClones[id] = {Model = clone, Joints = cloneJoints}
            end
        end
    end
end

local function playReplay()
    if #replayData == 0 then warn("No replay data.") return end
    cleanupGhosts()
    task.wait(0.1)
    playbackIndex = 1
    isPlaying = true
    activeClones = {}
    local firstFrame = replayData[1]
    if not firstFrame then isPlaying = false return end
    spawnGhosts(firstFrame)
    task.spawn(function()
        while isPlaying do
            playbackIndex = math.clamp(playbackIndex + playbackSpeed, 1, #replayData)
            local frameData = replayData[math.floor(playbackIndex)]
            if frameData then
                for id, ghost in pairs(activeClones) do
                    local pFrame = frameData[id]
                    if pFrame and ghost.Model then
                        ghost.Model:PivotTo(pFrame.Pivot)
                        for jName, transform in pairs(pFrame.Joints) do
                            local joint = ghost.Joints[jName]
                            if joint then joint.C0 = transform * joint.C1 end
                        end
                    end
                end
            end
            if motionBlurEnabled then
                motionBlur.Size = math.abs(playbackSpeed - 1) * 8
            else
                motionBlur.Size = 0
            end
            updateFrameLabel()
            local atEnd = playbackIndex >= #replayData and playbackSpeed > 0
            local atStart = playbackIndex <= 1 and playbackSpeed < 0
            if atEnd or atStart then
                if loopPlayback then
                    playbackIndex = playbackSpeed > 0 and 1 or #replayData
                else
                    break
                end
            end
            task.wait(1/60)
        end
        if not loopPlayback then cleanupGhosts() end
    end)
end

local function enableFreecam(enabled)
    FreecamEnabled = enabled
    if enabled then
        Controls:Disable()
        cam.CameraType = Enum.CameraType.Scriptable
        smoothCamCF = cam.CFrame
        local _, yaw, _ = cam.CFrame:ToEulerAnglesYXZ()
        rotY = yaw
    else
        Controls:Enable()
        cam.CameraType = Enum.CameraType.Custom
        moveVector = Vector3.new(0, 0, 0)
        camMode = "Free"
    end
end

UserInputService.TouchStarted:Connect(function(touch, processed)
    if not FreecamEnabled or processed then return end
    if touch.Position.X < cam.ViewportSize.X / 2 then
        moveTouch = touch; touchStartPos = touch.Position
    else
        lookTouch = touch
    end
end)

UserInputService.TouchMoved:Connect(function(touch)
    if not FreecamEnabled then return end
    if touch == moveTouch then
        local delta = touch.Position - touchStartPos
        moveVector = Vector3.new(delta.X / 50, 0, -delta.Y / 50)
    elseif touch == lookTouch then
        local delta = touch.Position - (lookTouch.Position or touch.Position)
        rotY = rotY - delta.X * lookSens
        rotX = math.clamp(rotX - delta.Y * lookSens, -1.5, 1.5)
    end
end)

UserInputService.TouchEnded:Connect(function(touch)
    if touch == moveTouch then moveTouch = nil; moveVector = Vector3.new(0,0,0)
    elseif touch == lookTouch then lookTouch = nil end
end)

RunService:BindToRenderStep("FlashbackCamera", Enum.RenderPriority.Camera.Value + 1, function(dt)
    if not FreecamEnabled then return end
    local ghostPivot = getGhostPivot()
    local mouseDelta = UserInputService:GetMouseDelta()

    if camMode == "Free" then
        local f = (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
        local s = (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
        local u = (UserInputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0)
        rotY = rotY - mouseDelta.X * lookSens
        rotX = math.clamp(rotX - mouseDelta.Y * lookSens, -1.5, 1.5)
        local rotation = CFrame.Angles(0, rotY, 0) * CFrame.Angles(rotX, 0, 0)
        local moveDir = rotation.LookVector * (f + moveVector.Z) + rotation.RightVector * (s + moveVector.X) + Vector3.new(0, u, 0)
        local targetCF = CFrame.new(cam.CFrame.Position + (moveDir.Magnitude > 0 and moveDir.Unit * camSpeed or Vector3.zero)) * rotation
        if cinematicCamera then
            smoothCamCF = smoothCamCF or targetCF
            smoothCamCF = smoothCamCF:Lerp(targetCF, math.clamp(dt * 8, 0, 1))
            cam.CFrame = smoothCamCF
        else
            cam.CFrame = targetCF
        end

    elseif camMode == "Lock" then
        if ghostPivot then
            rotY = rotY - mouseDelta.X * lookSens
            rotX = math.clamp(rotX - mouseDelta.Y * lookSens, -1.5, 1.5)
            local f = (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
            local s = (UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
            local u = (UserInputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0) - (UserInputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0)
            local rotation = CFrame.Angles(0, rotY, 0) * CFrame.Angles(rotX, 0, 0)
            local moveDir = rotation.LookVector * (f + moveVector.Z) + rotation.RightVector * (s + moveVector.X) + Vector3.new(0, u, 0)
            local offset = cam.CFrame.Position - ghostPivot.Position
            local newPos = ghostPivot.Position + offset + (moveDir.Magnitude > 0 and moveDir.Unit * camSpeed or Vector3.zero)
            local targetCF = CFrame.new(newPos, ghostPivot.Position)
            if cinematicCamera then
                smoothCamCF = smoothCamCF or targetCF
                smoothCamCF = smoothCamCF:Lerp(targetCF, math.clamp(dt * 6, 0, 1))
                cam.CFrame = smoothCamCF
            else
                cam.CFrame = targetCF
            end
        end

    elseif camMode == "Orbit" then
        if ghostPivot then
            orbitAngle = orbitAngle + mouseDelta.X * lookSens
            orbitHeight = orbitHeight - mouseDelta.Y * 0.1
            orbitDistance = math.clamp(orbitDistance - (UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or UserInputService:IsKeyDown(Enum.KeyCode.S) and -1 or 0) * camSpeed * 0.5, 2, 50)
            local ox = ghostPivot.Position.X + math.cos(orbitAngle) * orbitDistance
            local oz = ghostPivot.Position.Z + math.sin(orbitAngle) * orbitDistance
            local oy = ghostPivot.Position.Y + orbitHeight
            local targetCF = CFrame.new(Vector3.new(ox, oy, oz), ghostPivot.Position)
            if cinematicCamera then
                smoothCamCF = smoothCamCF or targetCF
                smoothCamCF = smoothCamCF:Lerp(targetCF, math.clamp(dt * 6, 0, 1))
                cam.CFrame = smoothCamCF
            else
                cam.CFrame = targetCF
            end
        end
    end
end)

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.R then
        if not recording then startRecording(); print("Recording...") else stopRecording(); print("Stopped. Frames:", #replayData) end
    elseif input.KeyCode == Enum.KeyCode.P then playReplay()
    elseif input.KeyCode == Enum.KeyCode.F then enableFreecam(not FreecamEnabled)
    elseif input.KeyCode == Enum.KeyCode.X then cleanupGhosts()
    elseif input.KeyCode == Enum.KeyCode.Left then playbackSpeed = 0; playbackIndex = math.clamp(playbackIndex - 1, 1, #replayData)
    elseif input.KeyCode == Enum.KeyCode.Right then playbackSpeed = 0; playbackIndex = math.clamp(playbackIndex + 1, 1, #replayData)
    end
end)

