local jointIndex = {}
local jointNames = {}
local jointCount = 0

local function getJointId(name)
    if not jointIndex[name] then
        jointCount += 1
        jointIndex[name] = jointCount
        jointNames[jointCount] = name
    end
    return jointIndex[name]
end

local function cfToNums(cf)
    local rx = cf.XVector
    local ry = cf.YVector
    local rz = cf.ZVector
    return cf.X, cf.Y, cf.Z,
        rx.X, ry.X, rz.X,
        rx.Y, ry.Y, rz.Y,
        rx.Z, ry.Z, rz.Z
end

local function numsToCf(a,b,c,d,e,f,g,h,i,j,k,l)
    return CFrame.new(a,b,c,d,e,f,g,h,i,j,k,l)
end

local function fmt(n)
    return tostring(math.floor(n * 1000000 + 0.5))
end

local function splitStr(s, sep)
    local t = {}
    for v in s:gmatch("([^" .. sep .. "]+)") do t[#t+1] = v end
    return t
end

local function serializeReplay(data)
    jointIndex = {}; jointNames = {}; jointCount = 0
    for _, frame in ipairs(data) do
        for _, pData in pairs(frame) do
            for jname in pairs(pData.Joints) do getJointId(jname) end
        end
    end
    local out = {}
    out[#out+1] = table.concat(jointNames, ",") .. "\n"
    for _, frame in ipairs(data) do
        local frameParts = {}
        for id, pData in pairs(frame) do
            local a,b,c,d,e,f,g,h,i,j,k,l = cfToNums(pData.Pivot)
            local parts = {id,fmt(a),fmt(b),fmt(c),fmt(d),fmt(e),fmt(f),fmt(g),fmt(h),fmt(i),fmt(j),fmt(k),fmt(l)}
            for jname, jt in pairs(pData.Joints) do
                local ja,jb,jc,jd,je,jf,jg,jh,ji,jj,jk,jl = cfToNums(jt)
                table.insert(parts, jointIndex[jname]..","..fmt(ja)..","..fmt(jb)..","..fmt(jc)..","..fmt(jd)..","..fmt(je)..","..fmt(jf)..","..fmt(jg)..","..fmt(jh)..","..fmt(ji)..","..fmt(jj)..","..fmt(jk)..","..fmt(jl))
            end
            frameParts[#frameParts+1] = table.concat(parts, ";")
        end
        out[#out+1] = table.concat(frameParts, "|") .. "\n"
    end
    return table.concat(out)
end

local function deserializeReplay(raw)
    local lines = splitStr(raw, "\n")
    if #lines < 2 then error("Invalid data: too few lines") end
    local localJointNames = splitStr(lines[1], ",")
    local data = {}
    local function parse(n)
        local v = tonumber(n)
        if not v then error("bad number: " .. tostring(n)) end
        return v / 1000000
    end
    for li = 2, #lines do
        local frame = {}
        local playerChunks = splitStr(lines[li], "|")
        for _, playerChunk in ipairs(playerChunks) do
            local segs = splitStr(playerChunk, ";")
            if #segs >= 13 then
                local id = segs[1]
                local pivot = numsToCf(parse(segs[2]),parse(segs[3]),parse(segs[4]),parse(segs[5]),parse(segs[6]),parse(segs[7]),parse(segs[8]),parse(segs[9]),parse(segs[10]),parse(segs[11]),parse(segs[12]),parse(segs[13]))
                local joints = {}
                for si = 14, #segs do
                    local jparts = splitStr(segs[si], ",")
                    if #jparts == 13 then
                        local jid = tonumber(jparts[1])
                        local jname = jid and localJointNames[jid]
                        if jname then
                            joints[jname] = numsToCf(parse(jparts[2]),parse(jparts[3]),parse(jparts[4]),parse(jparts[5]),parse(jparts[6]),parse(jparts[7]),parse(jparts[8]),parse(jparts[9]),parse(jparts[10]),parse(jparts[11]),parse(jparts[12]),parse(jparts[13]))
                        end
                    end
                end
                frame[id] = {Pivot = pivot, Joints = joints}
            end
        end
        if next(frame) then data[#data+1] = frame end
    end
    return data
end

local function getGhostPivot()
    for _, ghost in pairs(activeClones) do
        if ghost.Model then
            local hrp = ghost.Model:FindFirstChild("HumanoidRootPart")
            if hrp then return hrp.CFrame end
        end
    end
    return nil
end

local function cleanupGhosts()
    isPlaying = false
    cam.CameraType = Enum.CameraType.Custom
    Controls:Enable()
    cam.CameraSubject = lp.Character and lp.Character:FindFirstChild("Humanoid") or nil
    lp.CameraMode = Enum.CameraMode.Classic
    motionBlur.Size = 0
    for _, ghost in pairs(activeClones) do
        if ghost.Model then ghost.Model:Destroy() end
    end
    for _, v in ipairs(workspace:GetChildren()) do
        if v.Name == "Flashback_Ghost" then v:Destroy() end
    end
    activeClones = {}
end

local frameCountLabel
local function updateFrameLabel()
    if frameCountLabel then
        local total = #replayData
        local secs = math.floor(total / 60)
        local frames = total % 60
        if isPlaying then
            frameCountLabel.Text = ("▶ %d / %d  |  %ds %df"):format(math.floor(playbackIndex), total, secs, frames)
        elseif recording then
            frameCountLabel.Text = ("⏺ %d frames  |  %ds %df"):format(total, math.floor(total/60), total%60)
        else
            frameCountLabel.Text = ("Frames: %d  |  %ds %df"):format(total, secs, frames)
        end
    end
end

