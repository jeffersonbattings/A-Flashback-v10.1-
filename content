RunService:BindToRenderStep("FlashbackCamera", Enum.RenderPriority.Camera.Value+1, function(dt)
    if not FreecamEnabled then return end
    local ghostPivot = getGhostPivot()
    local mouseDelta = UserInputService:GetMouseDelta()
    if camMode=="Free" then
        local f=(UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
        local s=(UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
        local u=(UserInputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0)
        rotY=rotY-mouseDelta.X*lookSens
        rotX=math.clamp(rotX-mouseDelta.Y*lookSens,-1.5,1.5)
        local rotation=CFrame.Angles(0,rotY,0)*CFrame.Angles(rotX,0,0)
        local moveDir=rotation.LookVector*(f+moveVector.Z)+rotation.RightVector*(s+moveVector.X)+Vector3.new(0,u,0)
        local targetCF=CFrame.new(cam.CFrame.Position+(moveDir.Magnitude>0 and moveDir.Unit*camSpeed or Vector3.zero))*rotation
        if cinematicCamera then
            smoothCamCF=smoothCamCF or targetCF
            smoothCamCF=smoothCamCF:Lerp(targetCF,math.clamp(dt*8,0,1))
            cam.CFrame=smoothCamCF
        else cam.CFrame=targetCF end
    elseif camMode=="Lock" then
        if ghostPivot then
            rotY=rotY-mouseDelta.X*lookSens
            rotX=math.clamp(rotX-mouseDelta.Y*lookSens,-1.5,1.5)
            local f=(UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.S) and 1 or 0)
            local s=(UserInputService:IsKeyDown(Enum.KeyCode.D) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.A) and 1 or 0)
            local u=(UserInputService:IsKeyDown(Enum.KeyCode.E) and 1 or 0)-(UserInputService:IsKeyDown(Enum.KeyCode.Q) and 1 or 0)
            local rotation=CFrame.Angles(0,rotY,0)*CFrame.Angles(rotX,0,0)
            local moveDir=rotation.LookVector*(f+moveVector.Z)+rotation.RightVector*(s+moveVector.X)+Vector3.new(0,u,0)
            local offset=cam.CFrame.Position-ghostPivot.Position
            local newPos=ghostPivot.Position+offset+(moveDir.Magnitude>0 and moveDir.Unit*camSpeed or Vector3.zero)
            local targetCF=CFrame.new(newPos,ghostPivot.Position)
            if cinematicCamera then
                smoothCamCF=smoothCamCF or targetCF
                smoothCamCF=smoothCamCF:Lerp(targetCF,math.clamp(dt*6,0,1))
                cam.CFrame=smoothCamCF
            else cam.CFrame=targetCF end
        end
    elseif camMode=="Orbit" then
        if ghostPivot then
            orbitAngle=orbitAngle+mouseDelta.X*lookSens
            orbitHeight=orbitHeight-mouseDelta.Y*0.1
            orbitDistance=math.clamp(orbitDistance-(UserInputService:IsKeyDown(Enum.KeyCode.W) and 1 or UserInputService:IsKeyDown(Enum.KeyCode.S) and -1 or 0)*camSpeed*0.5,2,50)
            local ox=ghostPivot.Position.X+math.cos(orbitAngle)*orbitDistance
            local oz=ghostPivot.Position.Z+math.sin(orbitAngle)*orbitDistance
            local oy=ghostPivot.Position.Y+orbitHeight
            local targetCF=CFrame.new(Vector3.new(ox,oy,oz),ghostPivot.Position)
            if cinematicCamera then
                smoothCamCF=smoothCamCF or targetCF
                smoothCamCF=smoothCamCF:Lerp(targetCF,math.clamp(dt*6,0,1))
                cam.CFrame=smoothCamCF
            else cam.CFrame=targetCF end
        end
    end
end)

